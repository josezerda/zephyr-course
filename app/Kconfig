source "Kconfig.zephyr"

config APP_HEARTBEAT_PERIOD_MS
    int "Heartbeat LED blink period (ms)"
    default 500
    range 100 2000

menuconfig LED_SUBSYSTEM
    bool "LED Subsystem"
    default y

if LED_SUBSYSTEM

choice LED_BLINK_SLEEP
    prompt "LED blink sleep time"
    default LED_BLINK_1S

config LED_BLINK_250MS
    bool "250ms (fast)"

config LED_BLINK_500MS
    bool "500ms (slow)"

config LED_BLINK_1S
    bool "1s (medium)"

config LED_BLINK_2S
    bool "2s (very slow)"

endchoice

config LED_BLINK_SLEEP_MS
    int
    default 250  if LED_BLINK_250MS
    default 500  if LED_BLINK_500MS
    default 1000 if LED_BLINK_1S
    default 2000 if LED_BLINK_2S

menuconfig LED_ADVANCED
    bool "Advanced LED settings"

if LED_ADVANCED

config LED_BRIGHTNESS
    int "LED brightness (0-100)"
    range 0 100
    default 100

config LED_FADE_TIME
    int "LED fade duration (ms)"
    range 0 5000
    default 500

menu "Expert settings"
    visible if LED_ADVANCED

config LED_EXPERT_ENABLE
    bool "Enable LED debugging"

config LED_CUSTOM
    bool "Custom blink pattern"

endmenu

endif # LED_ADVANCED
endif # LED_SUBSYSTEM